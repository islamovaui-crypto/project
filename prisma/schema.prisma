generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GcUser {
  id        String   @id // GetCourse user ID
  email     String?
  phone     String?
  telegram  String?
  firstName String?
  lastName  String?
  birthDate String?
  age       String?
  niche     String?  // Ниша (для УНИВЕР): Вайбкодинг, Нейрокреатор, Архитектор
  refunded  Boolean  @default(false) // возврат — отображается красным, не учитывается в статистике
  lost      Boolean  @default(false) // потерянный — отображается оранжевым, не учитывается в статистике
  city      String?
  country   String?
  groups    String[] // GetCourse group IDs
  tags      String[]
  addfields Json? // custom fields
  gcCreatedAt DateTime?
  syncedAt  DateTime @default(now())

  orders         Order[]
  lessonProgress LessonProgress[]
  surveyAnswers  SurveyAnswer[]

  @@map("gc_users")
}

model Product {
  id   String  @id // GetCourse offer code or product ID
  name String
  gcId String?

  orders         Order[]
  lessonProgress LessonProgress[]
  surveys        Survey[]

  @@map("products")
}

model Order {
  id           String    @id // GetCourse deal ID
  dealNumber   String?
  userId       String
  productId    String?
  productTitle String?
  amount       Float?
  status       String // new, payed, cancelled, etc.
  isPaid       Boolean   @default(false)
  managerEmail String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  gcCreatedAt  DateTime?
  paidAt       DateTime?
  syncedAt     DateTime  @default(now())

  user    GcUser   @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("orders")
}

// Training (course) modules in GetCourse, e.g. "Модуль 1. Основы"
model TrainingModule {
  id         String          @id @default(cuid())
  streamId   String          @unique // GetCourse stream id
  title      String          // Модуль 1. Основы и инструменты
  course     String          // НейроАгент 3.0 / Вайбкодинг 2.0 / etc.
  order      Int             @default(0)
  syncedAt   DateTime?
  lessons    LessonStat[]

  @@map("training_modules")
}

// Per-lesson stats parsed from GetCourse statistics page
model LessonStat {
  id            String          @id @default(cuid())
  moduleId      String
  lessonId      String          // GetCourse lesson id
  title         String
  status        String          @default("")
  entered       Int             @default(0)
  answered      Int             @default(0)
  passed        Int?
  order         Int             @default(0)
  openDate      String?         // Дата открытия (как текст из GetCourse)
  syncedAt      DateTime        @default(now())

  module        TrainingModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  visits        UserLessonVisit[]

  @@unique([moduleId, lessonId])
  @@map("lesson_stats")
}

// Records that a user visited (entered) a specific lesson
model UserLessonVisit {
  id         String     @id @default(cuid())
  userId     String     // GetCourse user id (string)
  lessonStatId String
  visitedAt  DateTime   @default(now())

  lessonStat LessonStat @relation(fields: [lessonStatId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonStatId])
  @@index([userId])
  @@index([lessonStatId])
  @@map("user_lesson_visits")
}

model LessonProgress {
  id           String    @id @default(cuid())
  userId       String
  productId    String?
  lessonId     String
  lessonTitle  String?
  opened       Boolean   @default(false)
  completed    Boolean   @default(false)
  lastActivity DateTime?
  source       String    @default("webhook") // webhook | csv

  user    GcUser   @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Survey {
  id        String  @id @default(cuid())
  gcId      String  @unique // GetCourse survey/questionnaire ID
  name      String
  productId String?
  type      String  @default("onboarding") // onboarding | in-lesson

  product Product?       @relation(fields: [productId], references: [id])
  answers SurveyAnswer[]

  @@map("surveys")
}

model SurveyAnswer {
  id         String    @id @default(cuid())
  surveyId   String
  userId     String
  questionId String
  question   String?
  answer     String?
  answeredAt DateTime?
  source     String    @default("webhook") // webhook | csv

  survey Survey @relation(fields: [surveyId], references: [id])
  user   GcUser @relation(fields: [userId], references: [id])

  @@unique([surveyId, userId, questionId])
  @@map("survey_answers")
}

model ExcludedAccount {
  id        String   @id @default(cuid())
  userId    String? // GetCourse user ID
  email     String?
  tag       String? // exclude by tag
  groupId   String? // exclude by GetCourse group ID
  reason    String?
  createdAt DateTime @default(now())

  @@map("excluded_accounts")
}

model SyncLog {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String    @default("running") // running | success | error
  usersCount    Int?
  ordersCount   Int?
  paymentsCount Int?
  error         String?

  @@map("sync_logs")
}

model NpsResponse {
  id           String    @id @default(cuid())
  program      String
  expert       String?
  respondentId String?
  answeredAt   DateTime?
  name         String?
  email        String?
  lessons      Float?
  live         Float?
  curator      Float?
  organization Float?
  nps          Float?
  comment      String?
  reclassified Boolean   @default(false)
  sourceFile   String?
  importedAt   DateTime  @default(now())

  @@unique([email, program])
  @@map("nps_responses")
}
